diff --git a/test/functional/ui/leadingspacewidth_spec.lua b/test/functional/ui/leadingspacewidth_spec.lua
new file mode 100644
index 0000000000..6f46c53295
--- /dev/null
+++ b/test/functional/ui/leadingspacewidth_spec.lua
@@ -0,0 +1,195 @@
+local t = require('test.testutil')
+local n = require('test.functional.testnvim')()
+local Screen = require('test.functional.ui.screen')
+
+local clear = n.clear
+local feed = n.feed
+local command = n.command
+local api = n.api
+local eq = t.eq
+local fn = n.fn
+
+--- Set buffer lines directly, avoiding insert()'s dedent behavior.
+--- @param lines string[]
+local function set_lines(lines)
+  api.nvim_buf_set_lines(0, 0, -1, true, lines)
+end
+
+describe("'leadingspacewidth'", function()
+  local screen
+
+  before_each(function()
+    clear()
+    screen = Screen.new(40, 8)
+  end)
+
+  describe('option', function()
+    it('defaults to 0', function()
+      eq(0, api.nvim_get_option_value('leadingspacewidth', { buf = 0 }))
+    end)
+
+    it('can be set and get via abbreviation', function()
+      command('set lsw=3')
+      eq(3, api.nvim_get_option_value('leadingspacewidth', { buf = 0 }))
+    end)
+
+    it('rejects negative values', function()
+      local ok = pcall(command, 'set lsw=-1')
+      eq(false, ok)
+      eq(0, api.nvim_get_option_value('leadingspacewidth', { buf = 0 }))
+    end)
+
+    it('is buffer-local', function()
+      command('setlocal lsw=2')
+      command('new')
+      eq(0, api.nvim_get_option_value('leadingspacewidth', { buf = 0 }))
+    end)
+  end)
+
+  describe('display', function()
+    it('expands leading spaces when lsw=2', function()
+      -- 2 leading spaces → 4 screen cols; 4 leading spaces → 8 screen cols
+      set_lines({ '  hello', '    world' })
+      command('set lsw=2')
+      screen:expect([[
+        ^    hello                               |
+                world                           |
+        {1:~                                       }|*5
+                                                |
+      ]])
+    end)
+
+    it('expands leading spaces when lsw=3', function()
+      -- 2 leading spaces → 6 screen cols; 4 leading spaces → 12 screen cols
+      set_lines({ '  hello', '    world' })
+      command('set lsw=3')
+      screen:expect([[
+        ^      hello                             |
+                    world                       |
+        {1:~                                       }|*5
+                                                |
+      ]])
+    end)
+
+    it('does not affect non-leading spaces', function()
+      -- 2 leading spaces → 4 screen cols; interior space stays 1 col wide
+      set_lines({ '  hello world' })
+      command('set lsw=2')
+      screen:expect([[
+        ^    hello world                         |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+
+    it('does not affect all-whitespace lines', function()
+      -- line 1: "  hello" → 4 screen cols of indent
+      -- line 2: "   " (all whitespace) → NOT expanded (stays 3 spaces)
+      -- line 3: "  world" → 4 screen cols of indent
+      set_lines({ '  hello', '   ', '  world' })
+      command('set lsw=2')
+      screen:expect([[
+        ^    hello                               |
+                                                |
+            world                               |
+        {1:~                                       }|*4
+                                                |
+      ]])
+    end)
+
+    it('does not affect tab characters', function()
+      -- Tab should use tabstop, not lsw
+      set_lines({ '\thello' })
+      command('set tabstop=4 lsw=2')
+      screen:expect([[
+           ^ hello                               |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+
+    it('lsw=0 disables expansion (default)', function()
+      set_lines({ '  hello' })
+      command('set lsw=0')
+      screen:expect([[
+        ^  hello                                 |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+
+    it('lsw=1 renders at normal width', function()
+      set_lines({ '  hello' })
+      command('set lsw=1')
+      screen:expect([[
+        ^  hello                                 |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+
+    it('cursor position is correct on leading spaces', function()
+      set_lines({ '  hello' })
+      command('set lsw=2')
+      feed('0')
+      -- col('.') is 1-indexed byte column; cursor at column 1
+      eq(1, fn.col('.'))
+    end)
+
+    it('works with multiple indent levels', function()
+      set_lines({ 'no indent', '  level 1', '    level 2', '      level 3' })
+      command('set lsw=2')
+      screen:expect([[
+        ^no indent                               |
+            level 1                             |
+                level 2                         |
+                    level 3                     |
+        {1:~                                       }|*3
+                                                |
+      ]])
+    end)
+  end)
+
+  describe('with listchars', function()
+    it('composes with lead listchar', function()
+      -- 2 leading spaces × lsw=2 → 4 screen cols, each showing lead char
+      set_lines({ '  hello' })
+      command('set lsw=2 list listchars=lead:.')
+      screen:expect([[
+        {1:^.}.{1:.}.hello                               |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+
+    it('composes with leadmultispace listchar', function()
+      -- 4 leading spaces × lsw=2 → 8 screen cols with pattern ".-" repeating
+      set_lines({ '    hello' })
+      command('set lsw=2 list listchars=leadmultispace:.-')
+      screen:expect([[
+        {1:^.}.{1:-}-{1:.}.{1:-}-hello                           |
+        {1:~                                       }|*6
+                                                |
+      ]])
+    end)
+  end)
+
+  describe('cursor navigation', function()
+    it('virtcol returns correct virtual column', function()
+      set_lines({ '  hello' })
+      command('set lsw=2')
+      feed('0')
+      -- virtcol('.') returns the last screen column of the char under cursor.
+      -- With lsw=2, first space occupies vcols 1-2, so virtcol returns 2.
+      eq(2, fn.virtcol('.'))
+    end)
+
+    it('virtcol of text after indent is correct', function()
+      set_lines({ '  hello' })
+      command('set lsw=2')
+      feed('0w')
+      -- 2 spaces * 2 cols each = 4 cols of indent; 'h' is at virtual column 5
+      eq(5, fn.virtcol('.'))
+    end)
+  end)
+end)
