 runtime/plugin/leadingspacewidth.lua          |  54 +++++++
 .../plugin/leadingspacewidth_spec.lua         | 151 ++++++++++++++++++
 2 files changed, 205 insertions(+)
 create mode 100644 runtime/plugin/leadingspacewidth.lua
 create mode 100644 test/functional/plugin/leadingspacewidth_spec.lua

diff --git a/runtime/plugin/leadingspacewidth.lua b/runtime/plugin/leadingspacewidth.lua
new file mode 100644
index 0000000000..19d43fe05e
--- /dev/null
+++ b/runtime/plugin/leadingspacewidth.lua
@@ -0,0 +1,54 @@
+local group = vim.api.nvim_create_augroup('nvim.leadingspacewidth', {})
+
+--- Compute and set 'leadingspacewidth' for the given buffer.
+---
+--- Formula: lsw = tabstop / shiftwidth (when expandtab is set and
+--- tabstop is evenly divisible by shiftwidth). If lsw would be 1
+--- (no expansion), sets lsw to 0 (disabled).
+---
+--- @param bufnr integer
+local function compute_lsw(bufnr)
+  -- Buffer-local flag overrides global; default is false (opt-in).
+  local enable = vim.F.if_nil(
+    vim.b[bufnr].leadingspacewidth_auto,
+    vim.g.leadingspacewidth_auto,
+    false
+  )
+  if not enable then
+    return
+  end
+
+  -- Only for space-indented buffers.
+  if not vim.bo[bufnr].expandtab then
+    vim.bo[bufnr].leadingspacewidth = 0
+    return
+  end
+
+  local sw = vim.fn.shiftwidth() -- resolves 0 → tabstop
+  local ts = vim.bo[bufnr].tabstop
+
+  if sw <= 0 or ts <= 0 or ts % sw ~= 0 then
+    vim.bo[bufnr].leadingspacewidth = 0
+    return
+  end
+
+  local lsw = ts / sw
+  vim.bo[bufnr].leadingspacewidth = (lsw > 1) and lsw or 0
+end
+
+-- After file read (editorconfig fires on BufRead, so BufReadPost is after).
+vim.api.nvim_create_autocmd('BufReadPost', {
+  group = group,
+  callback = function(args)
+    compute_lsw(args.buf)
+  end,
+})
+
+-- React to mid-session option changes (e.g. vim-sleuth re-detecting on FileType).
+vim.api.nvim_create_autocmd('OptionSet', {
+  group = group,
+  pattern = { 'shiftwidth', 'expandtab', 'tabstop' },
+  callback = function()
+    compute_lsw(vim.api.nvim_get_current_buf())
+  end,
+})
diff --git a/test/functional/plugin/leadingspacewidth_spec.lua b/test/functional/plugin/leadingspacewidth_spec.lua
new file mode 100644
index 0000000000..dc72c1e130
--- /dev/null
+++ b/test/functional/plugin/leadingspacewidth_spec.lua
@@ -0,0 +1,151 @@
+local t = require('test.testutil')
+local n = require('test.functional.testnvim')()
+
+local clear = n.clear
+local command = n.command
+local eq = t.eq
+local api = n.api
+local pathsep = n.get_pathsep()
+
+local testdir = 'Xtest-leadingspacewidth'
+
+--- Helper: get lsw value for current buffer.
+local function get_lsw()
+  return api.nvim_get_option_value('leadingspacewidth', { buf = 0 })
+end
+
+setup(function()
+  n.mkdir_p(testdir)
+
+  -- Create test files (content doesn't matter, just need real files to :edit)
+  t.write_file(testdir .. pathsep .. 'space2.py', '  x = 1\n')
+  t.write_file(testdir .. pathsep .. 'space4.py', '    x = 1\n')
+  t.write_file(testdir .. pathsep .. 'tab.py', '\tx = 1\n')
+
+  -- EditorConfig that sets 2-space indent with tab_width=4
+  -- (tab_width controls tabstop separately from indent_size/shiftwidth)
+  t.write_file(
+    testdir .. pathsep .. '.editorconfig',
+    [[
+root = true
+
+[ec_space2.py]
+indent_style = space
+indent_size = 2
+tab_width = 4
+
+[ec_tab.py]
+indent_style = tab
+]]
+  )
+  t.write_file(testdir .. pathsep .. 'ec_space2.py', '  x = 1\n')
+  t.write_file(testdir .. pathsep .. 'ec_tab.py', '\tx = 1\n')
+end)
+
+teardown(function()
+  n.rmdir(testdir)
+end)
+
+describe('leadingspacewidth auto-computation', function()
+  before_each(function()
+    -- Remove -u NONE so that runtime plugins load (leadingspacewidth.lua, editorconfig.lua)
+    clear({ args_rm = { '-u' } })
+  end)
+
+  it('is disabled by default', function()
+    command('edit ' .. testdir .. pathsep .. 'space2.py')
+    eq(0, get_lsw())
+  end)
+
+  it('computes lsw=2 when ts=4, sw=2, et', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=2 expandtab')
+    eq(2, get_lsw())
+  end)
+
+  it('computes lsw=4 when ts=8, sw=2, et', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=8 shiftwidth=2 expandtab')
+    eq(4, get_lsw())
+  end)
+
+  it('sets lsw=0 when ts=sw (no expansion needed)', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=4 expandtab')
+    eq(0, get_lsw())
+  end)
+
+  it('sets lsw=0 for tab-indented buffers', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=2 noexpandtab')
+    eq(0, get_lsw())
+  end)
+
+  it('sets lsw=0 when ts/sw is indivisible', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=3 expandtab')
+    eq(0, get_lsw())
+  end)
+
+  it('reacts to OptionSet for shiftwidth', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=4 expandtab')
+    eq(0, get_lsw())
+
+    -- Change shiftwidth → lsw should update
+    command('set shiftwidth=2')
+    eq(2, get_lsw())
+  end)
+
+  it('reacts to OptionSet for expandtab', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=2 expandtab')
+    eq(2, get_lsw())
+
+    -- Switch to noexpandtab → lsw should reset
+    command('set noexpandtab')
+    eq(0, get_lsw())
+
+    -- Switch back → lsw should recompute
+    command('set expandtab')
+    eq(2, get_lsw())
+  end)
+
+  it('reacts to OptionSet for tabstop', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4 shiftwidth=2 expandtab')
+    eq(2, get_lsw())
+
+    -- Change tabstop → lsw should update
+    command('set tabstop=8')
+    eq(4, get_lsw())
+  end)
+
+  it('can be disabled per-buffer with vim.b flag', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+
+    -- Disable auto for this specific buffer
+    api.nvim_buf_set_var(0, 'leadingspacewidth_auto', false)
+    command('set tabstop=4 shiftwidth=2 expandtab')
+    eq(0, get_lsw())
+  end)
+
+  it('works with editorconfig integration', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+
+    -- Open file with .editorconfig setting indent_style=space, indent_size=2, tab_width=4
+    -- EditorConfig sets sw=2, et=true, ts=4 → auto-lsw computes lsw = 4/2 = 2
+    command('edit ' .. testdir .. pathsep .. 'ec_space2.py')
+    eq(2, get_lsw())
+  end)
+
+  it('skips tab-indented files via editorconfig', function()
+    api.nvim_set_var('leadingspacewidth_auto', true)
+    command('set tabstop=4')
+
+    -- Open file with .editorconfig setting indent_style=tab
+    -- EditorConfig sets et=false → auto-lsw skips, lsw=0
+    command('edit ' .. testdir .. pathsep .. 'ec_tab.py')
+    eq(0, get_lsw())
+  end)
+end)
