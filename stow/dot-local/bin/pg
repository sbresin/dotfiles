#!/usr/bin/env bash
# Spin up a project-local PostgreSQL container via Docker Compose.
#
# Data is stored in .postgres-data/ inside the project directory so each
# project gets its own isolated database that doesn't conflict with others.
# The port is deterministically derived from the project path so multiple
# projects can run simultaneously without collisions.
#
# Usage:
#   pg [start]               Start PostgreSQL (prints export statements)
#   pg stop                  Stop the container (data preserved)
#   pg destroy               Stop container and delete data
#   pg status                Show connection info and running state
#   pg url                   Print DATABASE_URL only
#   pg env                   Print export statements (without starting)
#
# Typical workflow:
#   eval $(pg start)         Start and load env vars into your shell
#   eval $(pg env)           Load env vars for an already-running instance
#
# Flags (for start command):
#   --port PORT              Override the auto-assigned port
#   --user USER              PostgreSQL user (default: postgres)
#   --db NAME                Database name (default: directory name)
#   --version VER            PostgreSQL version (default: 17)
#   --image IMAGE            Full image override (e.g. postgis/postgis:16-3.4)

set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────

COMPOSE_FILE=".docker-compose.postgres.yml"
DATA_DIR=".postgres-data"
PORT_RANGE_START=5500
PORT_RANGE_SIZE=500

# ── Helpers ──────────────────────────────────────────────────────────

die() { echo "pg: error: $*" >&2; exit 1; }
info() { echo "pg: $*" >&2; }

# Deterministic port from the absolute project path.
# Uses cksum (POSIX) to hash the path, then maps into the port range.
auto_port() {
	local hash
	hash=$(echo -n "$PWD" | cksum | awk '{print $1}')
	echo $(( PORT_RANGE_START + (hash % PORT_RANGE_SIZE) ))
}

# ── Configuration ────────────────────────────────────────────────────

# Defaults — can be overridden by flags or the existing compose file.
PG_PORT=""
PG_USER="postgres"
PG_DB="$(basename "$PWD")"
PG_VERSION="17"
PG_IMAGE=""

# Container name derived from project dir (sanitised for Docker).
CONTAINER_PREFIX="pg-$(basename "$PWD" | tr '[:upper:] ' '[:lower:]-')"

parse_flags() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--port)   PG_PORT="$2";    shift 2 ;;
			--user)   PG_USER="$2";    shift 2 ;;
			--db)     PG_DB="$2";      shift 2 ;;
			--version) PG_VERSION="$2"; shift 2 ;;
			--image)  PG_IMAGE="$2";   shift 2 ;;
			--help|-h) usage; exit 0 ;;
			-*)       die "unknown flag: $1" ;;
			*)        die "unexpected argument: $1" ;;
		esac
	done
}

resolve_config() {
	# Port: explicit flag > auto-detect from existing compose > hash-derived
	if [[ -z "$PG_PORT" ]]; then
		if [[ -f "$COMPOSE_FILE" ]]; then
			local existing_port
			existing_port=$(grep -oP '127\.0\.0\.1:\K[0-9]+(?=:5432)' "$COMPOSE_FILE" 2>/dev/null || true)
			if [[ -n "$existing_port" ]]; then
				PG_PORT="$existing_port"
			fi
		fi
	fi
	[[ -z "$PG_PORT" ]] && PG_PORT=$(auto_port)

	# Image: explicit flag > default from version
	[[ -z "$PG_IMAGE" ]] && PG_IMAGE="postgres:${PG_VERSION}"
}

# ── Compose file generation ──────────────────────────────────────────

generate_compose() {
	# Pre-create the data directory so the container (running as our UID)
	# doesn't need root to chmod the mount point.
	mkdir -p "$DATA_DIR"

	cat > "$COMPOSE_FILE" <<-YAML
	# Auto-generated by pg. Safe to edit — changes are preserved on restart
	# unless flags differ from what's here.
	services:
	  postgres:
	    image: ${PG_IMAGE}
	    container_name: ${CONTAINER_PREFIX}
	    user: "$(id -u):$(id -g)"
	    ports:
	      - "127.0.0.1:${PG_PORT}:5432"
	    environment:
	      POSTGRES_USER: "${PG_USER}"
	      POSTGRES_DB: "${PG_DB}"
	      POSTGRES_HOST_AUTH_METHOD: trust
	      PGDATA: /var/lib/postgresql/data/pgdata
	    volumes:
	      - ./${DATA_DIR}:/var/lib/postgresql/data
	    healthcheck:
	      test: ["CMD-SHELL", "pg_isready -U ${PG_USER} -d ${PG_DB}"]
	      interval: 2s
	      timeout: 3s
	      retries: 10
	YAML
}

should_regenerate() {
	# Regenerate if the file doesn't exist
	[[ ! -f "$COMPOSE_FILE" ]] && return 0

	# Regenerate if any flags were explicitly passed (user wants to change config)
	# We detect this by checking if the file matches current config
	local current_image current_port current_user current_db
	current_image=$(grep -oP 'image:\s*\K\S+' "$COMPOSE_FILE" 2>/dev/null || true)
	current_port=$(grep -oP '127\.0\.0\.1:\K[0-9]+(?=:5432)' "$COMPOSE_FILE" 2>/dev/null || true)
	current_user=$(grep -oP 'POSTGRES_USER:\s*"\K[^"]+' "$COMPOSE_FILE" 2>/dev/null || true)
	current_db=$(grep -oP 'POSTGRES_DB:\s*"\K[^"]+' "$COMPOSE_FILE" 2>/dev/null || true)

	[[ "$current_image" != "$PG_IMAGE" ]] && return 0
	[[ "$current_port" != "$PG_PORT" ]] && return 0
	[[ "$current_user" != "$PG_USER" ]] && return 0
	[[ "$current_db" != "$PG_DB" ]] && return 0

	return 1
}

# ── Env var output ───────────────────────────────────────────────────

print_exports() {
	local url="postgresql://${PG_USER}@127.0.0.1:${PG_PORT}/${PG_DB}"
	echo "export PGHOST=127.0.0.1"
	echo "export PGPORT=${PG_PORT}"
	echo "export PGUSER=${PG_USER}"
	echo "export PGDATABASE=${PG_DB}"
	echo "export DATABASE_URL=${url}"
}

print_url() {
	echo "postgresql://${PG_USER}@127.0.0.1:${PG_PORT}/${PG_DB}"
}

# ── Gitignore check ─────────────────────────────────────────────────

check_gitignore() {
	if [[ -f .gitignore ]]; then
		if ! grep -qxF "$DATA_DIR" .gitignore && ! grep -qxF "/$DATA_DIR" .gitignore && ! grep -qxF "$DATA_DIR/" .gitignore; then
			info "hint: add '$DATA_DIR' to your .gitignore"
		fi
		if ! grep -qxF "$COMPOSE_FILE" .gitignore && ! grep -qxF "/$COMPOSE_FILE" .gitignore; then
			info "hint: add '$COMPOSE_FILE' to your .gitignore"
		fi
	elif [[ -d .git ]]; then
		info "hint: no .gitignore found — consider adding '$DATA_DIR' and '$COMPOSE_FILE' to one"
	fi
}

# ── Commands ─────────────────────────────────────────────────────────

cmd_start() {
	parse_flags "$@"
	resolve_config

	if should_regenerate; then
		generate_compose
		info "wrote $COMPOSE_FILE (image=$PG_IMAGE port=$PG_PORT db=$PG_DB)"
	fi

	docker compose -f "$COMPOSE_FILE" up -d --wait >&2

	check_gitignore
	info "PostgreSQL is ready on port $PG_PORT"
	print_exports
}

cmd_stop() {
	[[ -f "$COMPOSE_FILE" ]] || die "no $COMPOSE_FILE found — nothing to stop"
	docker compose -f "$COMPOSE_FILE" down >&2
	info "stopped"
}

cmd_destroy() {
	if [[ -f "$COMPOSE_FILE" ]]; then
		docker compose -f "$COMPOSE_FILE" down -v >&2
	fi
	if [[ -d "$DATA_DIR" ]]; then
		rm -rf "$DATA_DIR"
		info "deleted $DATA_DIR"
	fi
	if [[ -f "$COMPOSE_FILE" ]]; then
		rm -f "$COMPOSE_FILE"
		info "deleted $COMPOSE_FILE"
	fi
	info "destroyed"
}

cmd_status() {
	resolve_config

	if [[ ! -f "$COMPOSE_FILE" ]]; then
		info "no $COMPOSE_FILE found — PostgreSQL has not been started in this directory"
		return 1
	fi

	local running
	running=$(docker compose -f "$COMPOSE_FILE" ps --status running -q 2>/dev/null || true)

	if [[ -n "$running" ]]; then
		info "running on port $PG_PORT (db=$PG_DB user=$PG_USER)"
		info "url: $(print_url)"
		info "data: $PWD/$DATA_DIR"
	else
		info "stopped (data in $DATA_DIR is preserved)"
		info "run 'pg start' to restart"
	fi
}

cmd_env() {
	parse_flags "$@"
	resolve_config
	print_exports
}

cmd_url() {
	resolve_config
	print_url
}

usage() {
	cat >&2 <<-'EOF'
	Usage: pg <command> [flags]

	Commands:
	  start   Start PostgreSQL container (default if no command given)
	  stop    Stop the container (data preserved)
	  destroy Stop container and delete all data
	  status  Show connection info and running state
	  url     Print DATABASE_URL
	  env     Print export statements without starting

	Flags (for start/env):
	  --port PORT      Override auto-assigned port (default: hash of project path)
	  --user USER      PostgreSQL user (default: postgres)
	  --db NAME        Database name (default: current directory name)
	  --version VER    PostgreSQL image version (default: 17)
	  --image IMAGE    Full Docker image (e.g. postgis/postgis:16-3.4)

	Examples:
	  eval $(pg)                         Quick start with defaults
	  eval $(pg start --port 5432)       Start on a specific port
	  eval $(pg start --image postgis/postgis:16-3.4)
	  pg stop                            Stop but keep data
	  pg destroy                         Stop and delete everything
	EOF
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
	local cmd="${1:-start}"

	case "$cmd" in
		start)   shift || true; cmd_start "$@" ;;
		stop)    cmd_stop ;;
		destroy) cmd_destroy ;;
		status)  cmd_status ;;
		url)     cmd_url ;;
		env)     shift; cmd_env "$@" ;;
		-h|--help) usage ;;
		-*)      # Flags without subcommand → treat as start
		         cmd_start "$@" ;;
		*)       die "unknown command: $cmd (try 'pg --help')" ;;
	esac
}

main "$@"
